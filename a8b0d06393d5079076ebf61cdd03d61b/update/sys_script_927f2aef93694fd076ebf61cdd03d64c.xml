        <script><![CDATA[(function executeRule(current, previous) {

    var pendingGR = new GlideRecord('x_1920756_univer_0_document_checklist');

    pendingGR.addQuery('admission_request', current.admission_request);
    pendingGR.addQuery('status', '!=', 'verified');

    pendingGR.query();

    if (pendingGR.hasNext())
        return;

    var admissionGR = current.admission_request.getRefRecord();

    if (!admissionGR.isValidRecord())
        return;

    admissionGR.status_field = 'pending_approval';

    admissionGR.update();

})(current, previous);]]></script>
